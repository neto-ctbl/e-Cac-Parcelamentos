# Arquivo de entrada. Pode ser CSV, XLSX, XLSM ou XLS.
INPUT_FILE=cnpjs.csv
OUTPUT_DIR=saida

# Preferência: chrome usa o Google Chrome instalado na máquina e tende a lidar melhor com certificado instalado.
BROWSER_CHANNEL=chrome
HEADLESS=false
SLOW_MO_MS=80

# Perfil persistente do Playwright. Ajuda a manter sessão/cache entre execuções.
USER_DATA_DIR=.pw-user-data

# true = pausa para você resolver captcha/janela de certificado quando aparecer.
MANUAL_CAPTCHA=true
MANUAL_CERTIFICATE=true

# Tempo padrão de espera, em ms.
TIMEOUT_MS=30000
